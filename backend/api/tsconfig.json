{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "../shared",
    "../../shared",
    "**/shared/**",
    "../**/shared/**"
  ]
}
