{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    /* Disable strict mode so your build stops failing */
    "strict": false,
    "noImplicitAny": false,

    /* Vite-friendly settings */
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    /* No output from tsc (Vite handles bundling) */
    "noEmit": true
  },

  /* Include your actual source code */
  "include": ["src"]
}
